; Engine configuration file.
;
; It's best edited using the editor UI and not directly,
; since the parameters that go here are not all obvious.
;
; Format:
;   [section] ; section goes between []
;   param=value ; assign values to parameters

config_version=5

[application]

config/name="Boss Battle Belay"
config/description="A roguelike where the boss remembers every run."
run/main_scene="res://scenes/main.tscn"
config/features=PackedStringArray("4.3", "GL Compatibility")
config/icon="res://icon.svg"

[autoload]

RunState="*res://autoload/run_state.gd"
SaveSystem="*res://autoload/save_system.gd"
DialogueDirector="*res://autoload/dialogue_director.gd"
ReplayRecorder="*res://autoload/replay_recorder.gd"
AudioBus="*res://autoload/audio_bus.gd"
BossSwap="*res://autoload/boss_swap.gd"
RevealDirector="*res://autoload/reveal_director.gd"
WeaponDict="*res://autoload/weapon_dict.gd"
ChoiceDirector="*res://autoload/choice_director.gd"

[display]

window/size/viewport_width=1080
window/size/viewport_height=1920
window/size/window_width_override=540
window/size/window_height_override=960
window/handheld/orientation=1
window/stretch/mode="canvas_items"
window/stretch/aspect="expand"

